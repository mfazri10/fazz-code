# Band platform URLs
THENVOI_REST_URL=https://app.band.ai/
THENVOI_WS_URL=wss://app.band.ai/api/v1/socket/websocket

# LLM provider keys (used for agent reasoning — separate from Band agent keys)
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here
GOOGLE_API_KEY=your-key-here

# Bridge to the Fazz Code Next.js app (used by the Fixer's generate_app tool)
FAZZ_API_URL=http://localhost:3000
# /api/generate requires an authenticated session. Paste a session cookie from a
# logged-in browser, e.g. "better-auth.session_token=..."
FAZZ_SESSION_COOKIE=
